{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (release)",
      "type": "shell",
      "command": "cargo build --release",
      "options": {
        "shell": { "executable": "/usr/bin/fish", "args": ["-c"] }
      },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Run overlay",
      "type": "shell",
      "command": "cargo build --release; and pkill -f rust-discord-overlay; sleep 0.5; ./target/release/rust-discord-overlay &",
      "options": {
        "shell": { "executable": "/usr/bin/fish", "args": ["-c"] }
      },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Release new version",
      "type": "shell",
      "command": "bash release.sh ${input:version}",
      "options": {
        "shell": { "executable": "/usr/bin/fish", "args": ["-c"] }
      },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Push (no release)",
      "type": "shell",
      "command": "git add -A; and git commit -m '${input:commitMsg}'; and git push",
      "options": {
        "shell": { "executable": "/usr/bin/fish", "args": ["-c"] }
      },
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ],
  "inputs": [
    {
      "id": "version",
      "type": "promptString",
      "description": "Nuova versione (es. 0.2.0)"
    },
    {
      "id": "commitMsg",
      "type": "promptString",
      "description": "Messaggio di commit"
    }
  ]
}
